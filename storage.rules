rules_version = '2';

// NBD Pro Firebase Storage Security Rules — HARDENED (2026-04-11)
// Deploy: firebase deploy --only storage
//
// Every path is owner-scoped by uid. "Public" customer-facing links now
// require a short-lived download token generated server-side — no more
// allow read; on user content.

service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { return isAuth() && request.auth.token.role == 'admin'; }

    // ── PHOTOS ─────────────────────────────────────────
    // Path: photos/{uid}/{file}
    // Owner (and admin) can read/write. No one else.
    match /photos/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 15 * 1024 * 1024   // 15 MB cap
        && request.resource.contentType.matches('image/.*');
    }

    // Legacy path: photos/<file> (no uid). Block new writes; read only via imageProxy.
    match /photos/{file} {
      allow read, write: if false;
    }

    // ── DOCUMENTS ──────────────────────────────────────
    // Path: docs/{uid}/{file}
    match /docs/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 25 * 1024 * 1024;   // 25 MB cap
    }
    match /docs/{file} {
      allow read, write: if false;
    }

    // ── CUSTOMER PORTALS ──────────────────────────────
    // Path: portals/{uid}/{leadId}.html
    // Not publicly readable. Customers get a signed URL from the imageProxy
    // or a portal-signing Cloud Function (to be added), not a direct CDN path.
    match /portals/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 5 * 1024 * 1024;
    }

    // ── DEAL ROOMS ─────────────────────────────────────
    match /deal_rooms/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 5 * 1024 * 1024;
    }

    // ── SHARED GALLERIES ──────────────────────────────
    match /galleries/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024;
    }

    // ── SHARED REPORTS ────────────────────────────────
    match /reports/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024;
    }

    // ── SHARED DOCUMENTS ──────────────────────────────
    match /shared_docs/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid)
        && request.resource.size < 25 * 1024 * 1024;
    }

    // ── DEFAULT DENY ──────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
