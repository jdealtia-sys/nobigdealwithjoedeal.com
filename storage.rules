rules_version = '2';

// NBD Pro Firebase Storage Security Rules
// Deploy: firebase deploy --only storage

service firebase.storage {
  match /b/{bucket}/o {

    // ── PHOTOS (dashboard upload path) ────────────────
    // Path: photos/{leadId}/{filename}
    match /photos/{leadId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024  // 15 MB limit
        && request.resource.contentType.matches('image/.*');
    }

    // ── DOCUMENTS ────────────────────────────────────
    // Path: docs/{filename}
    match /docs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;  // 25 MB limit
    }

    // ── DEFAULT: Deny everything else ────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
