rules_version = '2';

// NBD Pro Firestore Security Rules — HARDENED (2026-04-11)
// Deploy: firebase deploy --only firestore:rules
//
// Security model:
//   - Roles come from custom claims (`request.auth.token.role`), not from a
//     user-writable `users/{uid}.role` field.
//   - Broad `allow read: if isAuth()` is a footgun — every collection here
//     scopes reads to the resource owner, their company, or an admin.
//   - Subscription, rate_limits, access_codes, audit_log are admin-SDK-only.
//   - Public-write collections keep strict shape checks.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────
    //
    // Role taxonomy (custom claims):
    //   'admin'          → PLATFORM admin (support/ops). Cross-tenant.
    //                      Set only by a manual admin SDK script.
    //   'company_admin'  → tenant owner. Full access within own company.
    //   'manager'        → tenant manager. Read all team leads + reports.
    //   'sales_rep'      → individual rep. Owns their own docs only.
    //   'viewer'         → read-only inside their company.
    //
    // `isAdmin()` is now PLATFORM admin only — never use it on its own
    // for multi-tenant resources. Always pair it with
    // `sameCompanyAsResource()` or a company-scoped helper.
    function isAuth()    { return request.auth != null; }
    function isOwner(userId) { return isAuth() && request.auth.uid == userId; }
    function isAdmin()   { return isAuth() && request.auth.token.role == 'admin'; }
    function isCompanyAdmin() { return isAuth() && request.auth.token.role == 'company_admin'; }
    function isManager() { return isAuth() && request.auth.token.role == 'manager'; }

    function myCompanyId() {
      return request.auth.token.companyId;
    }

    function sameCompanyAsResource() {
      // CRITICAL: require BOTH sides to be non-null. A token without a
      // companyId claim would otherwise pass this check against any
      // legacy doc whose companyId field was never set.
      return isAuth()
        && request.auth.token.companyId != null
        && resource.data.companyId != null
        && resource.data.companyId == request.auth.token.companyId;
    }

    // Company admin / manager acting inside their own tenant. Use this
    // for "see any lead in my team" style rules — NOT isAdmin() alone.
    function isCompanyStaff() {
      return isCompanyAdmin() || isManager();
    }

    // Field-diff helper used by users/<uid> to block privilege escalation.
    function didNotChange(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ── LEADS ─────────────────────────────────────────
    match /leads/{leadId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /leads/{uid}/leads/{leadId} {
      allow read, write: if isOwner(uid) || isAdmin();
      match /activity/{activityId} { allow read, write: if isOwner(uid) || isAdmin(); }
      match /tasks/{taskId}        { allow read, write: if isOwner(uid) || isAdmin(); }
      match /notes/{noteId}        { allow read, write: if isOwner(uid) || isAdmin(); }
    }

    // ── ESTIMATES ─────────────────────────────────────
    match /estimates/{estimateId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── PHOTOS ────────────────────────────────────────
    match /photos/{photoId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── MAP PINS ──────────────────────────────────────
    match /pins/{pinId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── TASKS ─────────────────────────────────────────
    match /tasks/{taskId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── NOTIFICATIONS ─────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      // Creation is server-side (admin SDK). Allow self-create too for client-initiated flows
      // but only if the userId matches the caller, to prevent cross-tenant spam.
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── EMAILS (sent log) ─────────────────────────────
    match /emails/{emailId} {
      allow read: if isAuth() && resource.data.sentBy == request.auth.token.email;
      allow create: if isAuth() && request.resource.data.sentBy == request.auth.token.email;
    }

    // ── DOCUMENTS ─────────────────────────────────────
    match /documents/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── NOTES ─────────────────────────────────────────
    match /notes/{noteId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── USER SETTINGS / PROFILE ───────────────────────
    // Profile is self-owned but privileged fields are locked to the server.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && !request.resource.data.keys().hasAny(['role','plan','accessCode','isAdmin','companyId']);
      allow update: if isOwner(uid)
        && didNotChange(['role','plan','accessCode','isAdmin','companyId']);
      allow delete: if isAdmin();

      match /{subcol}/{docId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /userSettings/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── SUBSCRIPTIONS ─────────────────────────────────
    // READ-ONLY for the owner. All writes go through the Stripe webhook or
    // the hardened validateAccessCode Cloud Function (admin SDK).
    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // ── ACCESS CODES ──────────────────────────────────
    // Admin-SDK-only. Clients can neither read nor write.
    match /access_codes/{codeId} {
      allow read, write: if false;
    }

    // ── LEADERBOARD ───────────────────────────────────
    // Readable only within the same company (or admin). Writable only by the owner.
    match /leaderboard/{uid} {
      allow read: if isAdmin()
        || isOwner(uid)
        || (isAuth() && myCompanyId() != null && resource.data.companyId == myCompanyId());
      allow write: if isOwner(uid);
    }

    // ── API USAGE LOGGING ─────────────────────────────
    // Writes happen via admin SDK (Cloud Function). Reads: own usage or admin.
    match /api_usage/{docId} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── RATE LIMITS (admin-SDK only) ──────────────────
    match /rate_limits/{uid}        { allow read, write: if false; }
    match /_rate_limits_ip/{docId}  { allow read, write: if false; }

    // ── DAILY SUCCESS ─────────────────────────────────
    match /daily_entries/{uid}/entries/{entryId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── DAILY TRACKER ────────────────────────────────
    match /dailyTracker/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── D2D KNOCKS ────────────────────────────────────
    match /knocks/{knockId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || (isManager() && sameCompanyAsResource());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── REPS (team member profiles) ──────────────────
    // Reads scoped to same company or admin. Never globally enumerable.
    match /reps/{repId} {
      allow read: if isAdmin()
        || isOwner(repId)
        || (isAuth() && myCompanyId() != null && resource.data.companyId == myCompanyId());
      allow create: if isOwner(repId)
        && !request.resource.data.keys().hasAny(['role','isAdmin']);
      allow update: if (isOwner(repId) && didNotChange(['role','isAdmin','companyId']))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ── TERRITORIES ──────────────────────────────────
    match /territories/{territoryId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || (isAuth() && myCompanyId() != null && resource.data.companyId == myCompanyId());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── PRODUCTS ──────────────────────────────────────
    match /products/{productId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── TEMPLATES ─────────────────────────────────────
    match /templates/{templateId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── COMPANIES ─────────────────────────────────────
    match /companies/{companyId} {
      // Readable by members of that company, the owner, or admin.
      allow read: if isAdmin()
        || (isAuth() && resource.data.ownerId == request.auth.uid)
        || (isAuth() && myCompanyId() == companyId);
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if (isAuth() && resource.data.ownerId == request.auth.uid) || isAdmin();

      // Members subcollection is writable only by the company owner or admin.
      match /members/{memberId} {
        allow read: if isAdmin()
          || (isAuth() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid)
          || (isAuth() && request.auth.uid == memberId);
        allow create, update, delete: if isAdmin()
          || (isAuth() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid);
      }
    }

    // ── TRAINING SESSIONS ────────────────────────────
    match /training_sessions/{sessionId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || (isManager() && sameCompanyAsResource());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── PUBLIC LEAD FORMS ────────────────────────────
    // Direct client creates are DISABLED (C-3). Public forms must now
    // post through the `submitPublicLead` Cloud Function, which enforces
    // App Check + per-IP rate limit + honeypot + origin allowlist before
    // writing here via the admin SDK. Rules can't rate-limit, so direct
    // creates are an unbounded spam/billing DoS vector.
    match /guide_leads/{leadId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    match /contact_leads/{leadId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    match /estimate_leads/{leadId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    match /storm_alert_subscribers/{subId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    // ── STORM ALERTS SENT LOG (Cloud Function only) ──
    match /storm_alerts_sent/{alertId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── OTP / VERIFIED PHONES (admin-SDK only) ───────
    match /otp_requests/{docId}    { allow read, write: if false; }
    match /verified_phones/{phone} { allow read, write: if false; }
    match /unmatched_sms/{docId}   { allow read: if isAdmin(); allow write: if false; }

    // ── INVOICES ─────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read, update, delete: if isOwner(resource.data.createdBy) || isAdmin();
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
    }

    // ── EMAIL DRIP ───────────────────────────────────
    match /drip_queue/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    match /drip_log/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── EMAIL / SMS LOG (admin-SDK write, owner read) ─
    match /email_log/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if false;
    }
    match /sms_log/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if false;
    }

    // ── LEAD DOCUMENTS ───────────────────────────────
    match /lead_documents/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── REFERRALS ────────────────────────────────────
    match /referrals/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── REVIEW REQUESTS ──────────────────────────────
    match /review_requests/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── REPORTS ──────────────────────────────────────
    match /reports/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── INVITES (admin-SDK only) ─────────────────────
    match /invites/{token} { allow read, write: if false; }

    // ── AUDIT LOG (admin-only reads, admin-SDK writes) ─
    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── PORTAL TOKENS (admin-SDK only) ─────────────────
    // Minted by createPortalToken, consumed by getHomeownerPortalView.
    // Tokens are sensitive — a leaked token grants read of a
    // homeowner's redacted project view, so clients get no direct
    // access. The homeowner-facing page talks to the HTTP endpoint.
    match /portal_tokens/{token} {
      allow read, write: if false;
    }

    // ── PARCEL CACHE (admin-SDK only) ──────────────────
    // Regrid lookup cache — reads are a privacy issue (address →
    // owner name). Only the Cloud Function accesses via admin SDK.
    match /parcel_cache/{key} {
      allow read, write: if false;
    }

    // ── MEASUREMENTS (rep owner-scoped) ────────────────
    // Created by requestMeasurement, filled by measurementWebhook.
    // Owner can read to pre-fill the V2 Builder; writes are admin-
    // SDK only (webhook).
    match /measurements/{jobId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow write: if false;
    }

    // ── APPOINTMENTS (Cal.com webhook output) ──────────
    // Written by calcomWebhook, read by the owning rep.
    match /appointments/{bookingId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── DEFAULT DENY ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
