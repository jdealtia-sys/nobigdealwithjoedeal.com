rules_version = '2';

// NBD Pro Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isCurrentUser() {
      return isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── LEADS ─────────────────────────────────────────
    // Users can only read/write their own leads (userId field)
    match /leads/{leadId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Nested leads path (crm-leads.js architecture)
    match /leads/{uid}/leads/{leadId} {
      allow read, write: if isOwner(uid);

      // Activity sub-collection
      match /activity/{activityId} {
        allow read, write: if isOwner(uid);
      }

      // Tasks sub-collection
      match /tasks/{taskId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── ESTIMATES ─────────────────────────────────────
    match /estimates/{estimateId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── PHOTOS ────────────────────────────────────────
    match /photos/{photoId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── MAP PINS ──────────────────────────────────────
    match /pins/{pinId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── TASKS ─────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── NOTIFICATIONS ─────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── EMAILS (sent log) ─────────────────────────────
    match /emails/{emailId} {
      allow read: if isAuth() && resource.data.sentBy == request.auth.token.email;
      allow create: if isAuth();
    }

    // ── DOCUMENTS ─────────────────────────────────────
    match /documents/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── NOTES ─────────────────────────────────────────
    match /notes/{noteId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── USER SETTINGS ─────────────────────────────────
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /{subcol}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── SUBSCRIPTIONS ─────────────────────────────────
    // Users can read their own subscription; only server/registration can create/update
    match /subscriptions/{uid} {
      allow read: if isOwner(uid);
      // Allow create during registration (user creating their own sub doc)
      allow create: if isOwner(uid)
        && request.resource.data.plan is string
        && request.resource.data.status is string;
      // Allow update only if user is updating their own doc
      // (Stripe webhooks should use admin SDK which bypasses rules)
      allow update: if isOwner(uid);
    }

    // ── ACCESS CODES ──────────────────────────────────
    // Read-only for all authenticated users (registration validation)
    match /access_codes/{codeId} {
      allow read: if isAuth();
    }

    // ── LEADERBOARD (read-only for all auth users, write for self) ──
    match /leaderboard/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ── API USAGE LOGGING ─────────────────────────────
    match /api_usage/{docId} {
      allow create: if isAuth();
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // ── RATE LIMITS (Cloud Function managed) ──────────
    match /rate_limits/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── DAILY SUCCESS ─────────────────────────────────
    match /daily_entries/{uid}/entries/{entryId} {
      allow read, write: if isOwner(uid);
    }

    // ── D2D KNOCKS (door-to-door tracking) ─────────────
    match /knocks/{knockId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── D2D KNOCKS (team-scoped reads for managers) ──
    // Managers can read all knocks for their company
    match /knocks/{knockId} {
      allow read: if isAuth() && resource.data.companyId != null
        && exists(/databases/$(database)/documents/reps/$(request.auth.uid))
        && get(/databases/$(database)/documents/reps/$(request.auth.uid)).data.role == 'manager'
        && resource.data.companyId == get(/databases/$(database)/documents/reps/$(request.auth.uid)).data.companyId;
    }

    // ── REPS (team member profiles) ──────────────────
    match /reps/{repId} {
      allow read: if isAuth();
      allow create: if isAuth() && repId == request.auth.uid;
      allow update: if isOwner(repId);
      allow delete: if isOwner(repId);
    }

    // ── TERRITORIES (D2D territory polygons) ─────────
    match /territories/{territoryId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── PRODUCTS (user-scoped product catalog) ────────
    match /products/{productId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── TEMPLATES (user-scoped template library) ──────
    match /templates/{templateId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── COMPANIES (company profiles & team) ───────────
    match /companies/{companyId} {
      allow read: if isAuth();
      allow write: if isAuth() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;

      // Team members sub-collection
      match /members/{memberId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    // ── TRAINING SESSIONS (sales training progress) ──
    match /training_sessions/{sessionId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── TRAINING SESSIONS (team reads for managers) ──
    match /training_sessions/{sessionId} {
      allow read: if isAuth() && resource.data.companyId != null
        && exists(/databases/$(database)/documents/reps/$(request.auth.uid))
        && get(/databases/$(database)/documents/reps/$(request.auth.uid)).data.role == 'manager'
        && resource.data.companyId == get(/databases/$(database)/documents/reps/$(request.auth.uid)).data.companyId;
    }

    // ── DEFAULT: Deny everything else ─────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
