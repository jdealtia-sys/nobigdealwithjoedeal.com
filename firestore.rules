rules_version = '2';

// NBD Pro Firestore Security Rules — HARDENED (2026-04-11)
// Deploy: firebase deploy --only firestore:rules
//
// Security model:
//   - Roles come from custom claims (`request.auth.token.role`), not from a
//     user-writable `users/{uid}.role` field.
//   - Broad `allow read: if isAuth()` is a footgun — every collection here
//     scopes reads to the resource owner, their company, or an admin.
//   - Subscription, rate_limits, access_codes, audit_log are admin-SDK-only.
//   - Public-write collections keep strict shape checks.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────
    //
    // Role taxonomy (custom claims):
    //   'admin'          → PLATFORM admin (support/ops). Cross-tenant.
    //                      Set only by a manual admin SDK script.
    //   'company_admin'  → tenant owner. Full access within own company.
    //   'manager'        → tenant manager. Read all team leads + reports.
    //   'sales_rep'      → individual rep. Owns their own docs only.
    //   'viewer'         → read-only inside their company.
    //
    // `isAdmin()` is now PLATFORM admin only — never use it on its own
    // for multi-tenant resources. Always pair it with
    // `sameCompanyAsResource()` or a company-scoped helper.
    function isAuth()    { return request.auth != null; }
    function isOwner(userId) { return isAuth() && request.auth.uid == userId; }
    function isAdmin()   { return isAuth() && request.auth.token.role == 'admin'; }
    function isCompanyAdmin() { return isAuth() && request.auth.token.role == 'company_admin'; }
    function isManager() { return isAuth() && request.auth.token.role == 'manager'; }

    function myCompanyId() {
      return request.auth.token.companyId;
    }

    function sameCompanyAsResource() {
      // CRITICAL: require BOTH sides to be non-null. A token without a
      // companyId claim would otherwise pass this check against any
      // legacy doc whose companyId field was never set.
      return isAuth()
        && request.auth.token.companyId != null
        && resource.data.companyId != null
        && resource.data.companyId == request.auth.token.companyId;
    }

    // Company admin / manager acting inside their own tenant. Use this
    // for "see any lead in my team" style rules — NOT isAdmin() alone.
    function isCompanyStaff() {
      return isCompanyAdmin() || isManager();
    }

    // Field-diff helper used by users/<uid> to block privilege escalation.
    function didNotChange(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ── LEADS ─────────────────────────────────────────
    // companyId is required on create. The Rock 3 backfill
    // (PR #56 audit/backfill callable) stamped companyId on every
    // pre-existing lead, so the field is now an invariant — every
    // lead in /leads/{leadId} must carry the creator's tenant scope.
    // Enforcing it here closes the "stray lead with no companyId"
    // hole that would otherwise let team-scoped queries (managers,
    // leaderboard rollups) silently miss new records.
    //
    // Token-claim ownership match (companyId == myCompanyId()) is
    // intentionally NOT enforced yet — that's a follow-up after
    // verifying every active user's custom claims include companyId.
    match /leads/{leadId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0;

      // D3: flat-path subcollections — the measurementWebhook +
      // esignWebhook auto-append activity here via admin SDK. Rules
      // only expose READ to the lead's owner + platform admin;
      // writes are admin-SDK only so webhook-stamped events can't
      // be forged by a rep.
      //
      // F-05: tightened. Reps can append manual notes/calls/sms/etc.
      // but can NOT fabricate webhook- or payment-shaped entries.
      // Every client-written activity must declare `source: 'rep'`
      // and restrict `type` to the human-action allowlist. Any
      // financial or webhook-scoped fields are disallowed on client
      // writes; those come only from admin SDK (webhooks).
      match /activity/{activityId} {
        allow read:  if isAuth() && (isAdmin()
          || isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId));
        // Reps can append their own notes/activity via direct write; the
        // rule enforces shape. Webhook-written activities (measurement,
        // stripe, esign, calcom) bypass these rules via admin SDK.
        allow create: if isAuth()
          && request.resource.data.userId == request.auth.uid
          && isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId)
          && request.resource.data.source == 'rep'
          && request.resource.data.type in [
               'note', 'call', 'sms_out', 'email_out',
               'photo_added', 'task_done', 'appointment_set',
               'door_knock', 'follow_up', 'status_change'
             ]
          && !(request.resource.data.keys().hasAny([
               'stripeInvoiceId', 'stripeCustomerId', 'stripePaymentIntentId',
               'amountCents', 'hostedInvoiceUrl',
               'signatureDocumentId', 'signatureProvider',
               'externalJobId', 'measurements', 'reportUrl'
             ]));
        allow update, delete: if false;
      }
      match /tasks/{taskId} {
        allow read:   if isAuth() && (isAdmin()
          || isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId));
        allow write:  if isAuth()
          && isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId);
      }
      match /notes/{noteId} {
        allow read:   if isAuth() && (isAdmin()
          || isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId));
        allow write:  if isAuth()
          && isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId);
      }

      // ── RECORDINGS (Voice Intelligence) ───────────────
      // C2 — written by the Storage-triggered pipeline
      // (functions/integrations/voice-intelligence.js) via admin
      // SDK; clients never write directly so shape forgery is
      // impossible (same pattern as F-05 activity rule).
      //
      // Reads: lead owner, platform admin, or a company manager
      // whose companyId matches the recording's stamped companyId.
      // The company-scope check lets team managers review their
      // reps' calls without cross-tenant leakage.
      //
      // Audio files live at audio/{uid}/{leadId}/{recordingId}.ext
      // in Storage (see storage.rules); the doc here is the
      // transcript + structured summary + metadata.
      match /recordings/{recordingId} {
        allow read: if isAuth() && (
          isAdmin()
          || isOwner(resource.data.userId)
          || (isManager()
              && resource.data.companyId != null
              && resource.data.companyId == myCompanyId())
        );
        allow write: if false;  // admin SDK only
      }

      // ── DOCUMENTS attached to a lead ──────────────────
      // Generated proposals/contracts/invoices/etc. that the rep
      // attaches to a customer record. Same auth shape as notes/tasks
      // — readable + writable by the lead owner (or admin). Without
      // this rule the Firestore default-deny silently hid every
      // attached document from the customer page documents list.
      match /documents/{documentId} {
        allow read:  if isAuth() && (isAdmin()
          || isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId));
        allow write: if isAuth()
          && isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId);
      }

      // ── DRAWINGS (roof measurements, sketches) ────────
      // Persistent maps.js drawings keyed under the lead. Same
      // owner-or-admin auth pattern. Default-deny was hiding every
      // saved drawing on customer page reload.
      match /drawings/{drawingId} {
        allow read:  if isAuth() && (isAdmin()
          || isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId));
        allow write: if isAuth()
          && isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.userId);
      }
    }

    // Audit #23: the nested /leads/{uid}/leads/{leadId} rule was a leftover
    // from an earlier nested schema. The live app stores leads flat at
    // /leads/{leadId} (see rule above). Only archived code under
    // docs/pro/js/_archive/ still references the nested path, so this rule
    // was granting unused read/write surface area. Removed — flat rule above
    // is the canonical path.

    // ── ESTIMATES ─────────────────────────────────────
    match /estimates/{estimateId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── PHOTOS ────────────────────────────────────────
    match /photos/{photoId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── MAP PINS ──────────────────────────────────────
    match /pins/{pinId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── TASKS ─────────────────────────────────────────
    match /tasks/{taskId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── COMMUNICATIONS (call / email / SMS log) ───────
    // Written from customer.html when a rep taps call / email / SMS
    // shortcut buttons. Owner scope by userId.
    match /communications/{commId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── NOTIFICATIONS ─────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      // Creation is server-side (admin SDK). Allow self-create too for client-initiated flows
      // but only if the userId matches the caller, to prevent cross-tenant spam.
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── EMAILS (sent log) ─────────────────────────────
    match /emails/{emailId} {
      allow read: if isAuth() && resource.data.sentBy == request.auth.token.email;
      allow create: if isAuth() && request.resource.data.sentBy == request.auth.token.email;
    }

    // ── DOCUMENTS ─────────────────────────────────────
    match /documents/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── NOTES ─────────────────────────────────────────
    match /notes/{noteId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── USER SETTINGS / PROFILE ───────────────────────
    // Profile is self-owned but privileged fields are locked to the server.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && !request.resource.data.keys().hasAny(['role','plan','accessCode','isAdmin','companyId']);
      allow update: if isOwner(uid)
        && didNotChange(['role','plan','accessCode','isAdmin','companyId']);
      allow delete: if isAdmin();

      match /{subcol}/{docId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /userSettings/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── SUBSCRIPTIONS ─────────────────────────────────
    // READ-ONLY for the owner. All writes go through the Stripe webhook or
    // the hardened validateAccessCode Cloud Function (admin SDK).
    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // ── ACCESS CODES ──────────────────────────────────
    // Admin-SDK-only. Clients can neither read nor write.
    match /access_codes/{codeId} {
      allow read, write: if false;
    }

    // ── LEADERBOARD ───────────────────────────────────
    // Readable within the same company (or admin/owner). Writes are
    // admin-SDK only — counters must come from a Cloud Function that
    // aggregates authoritative data, never from the client. This
    // prevents trivial inflation of closedDeals/revenue from the rep's
    // own session.
    match /leaderboard/{uid} {
      allow read: if isAdmin()
        || isOwner(uid)
        || (isAuth() && myCompanyId() != null && resource.data.companyId == myCompanyId());
      allow write: if false;
    }

    // ── COUNTERS (atomic ID sequences) ────────────────
    // Used by dashboard.html + customer.html runTransaction calls to
    // mint sequential customer IDs (NBD-####). Without this rule the
    // default-deny at the bottom rejected every transaction and the
    // catches silently console.warn'd, so no lead ever got an ID.
    // Auth-only — the counter doc holds an integer; tampering at worst
    // skips numbers, never escalates privilege. Worth a lock-down to a
    // Cloud Function someday but the current shape is safe to expose.
    match /counters/{counterId} {
      allow read, write: if isAuth();
    }

    // ── API USAGE LOGGING ─────────────────────────────
    // Writes happen via admin SDK (Cloud Function). Reads: own usage or admin.
    match /api_usage/{docId} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── API USAGE DAILY COUNTERS (admin-SDK only) ─────
    // M2: materialized per-(day, uid) and per-(day, company) token
    // counters that replace the N-doc range scan on the claudeProxy
    // hot path. Clients see budget headroom only via the 429
    // response — direct reads would be an information-leak surface
    // AND an abuse vector (a client that can read the counter could
    // time-probe it for competitor intel).
    match /api_usage_daily/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── RATE LIMITS (admin-SDK only) ──────────────────
    match /rate_limits/{uid}        { allow read, write: if false; }
    match /_rate_limits_ip/{docId}  { allow read, write: if false; }

    // ── DAILY SUCCESS ─────────────────────────────────
    match /daily_entries/{uid}/entries/{entryId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── DAILY TRACKER ────────────────────────────────
    match /dailyTracker/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── D2D KNOCKS ────────────────────────────────────
    match /knocks/{knockId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || (isManager() && sameCompanyAsResource());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── REPS (team member profiles) ──────────────────
    // Reads scoped to same company or admin. Never globally enumerable.
    match /reps/{repId} {
      allow read: if isAdmin()
        || isOwner(repId)
        || (isAuth() && myCompanyId() != null && resource.data.companyId == myCompanyId());
      allow create: if isOwner(repId)
        && !request.resource.data.keys().hasAny(['role','isAdmin']);
      allow update: if (isOwner(repId) && didNotChange(['role','isAdmin','companyId']))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ── TERRITORIES ──────────────────────────────────
    match /territories/{territoryId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || (isAuth() && myCompanyId() != null && resource.data.companyId == myCompanyId());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── PRODUCTS ──────────────────────────────────────
    match /products/{productId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── TEMPLATES ─────────────────────────────────────
    match /templates/{templateId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── COMPANIES ─────────────────────────────────────
    match /companies/{companyId} {
      // Readable by members of that company, the owner, or admin.
      allow read: if isAdmin()
        || (isAuth() && resource.data.ownerId == request.auth.uid)
        || (isAuth() && myCompanyId() == companyId);
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if (isAuth() && resource.data.ownerId == request.auth.uid) || isAdmin();

      // Members subcollection is writable only by the company owner or admin.
      match /members/{memberId} {
        allow read: if isAdmin()
          || (isAuth() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid)
          || (isAuth() && request.auth.uid == memberId);
        allow create, update, delete: if isAdmin()
          || (isAuth() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid);
      }
    }

    // ── TRAINING SESSIONS ────────────────────────────
    match /training_sessions/{sessionId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || (isManager() && sameCompanyAsResource());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── PUBLIC LEAD FORMS ────────────────────────────
    // Direct client creates are DISABLED (C-3). Public forms must now
    // post through the `submitPublicLead` Cloud Function, which enforces
    // App Check + per-IP rate limit + honeypot + origin allowlist before
    // writing here via the admin SDK. Rules can't rate-limit, so direct
    // creates are an unbounded spam/billing DoS vector.
    match /guide_leads/{leadId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    match /contact_leads/{leadId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    match /estimate_leads/{leadId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    match /storm_alert_subscribers/{subId} {
      allow create, update, delete: if false;
      allow read: if isAdmin();
    }

    // ── STORM ALERTS SENT LOG (Cloud Function only) ──
    match /storm_alerts_sent/{alertId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── OTP / VERIFIED PHONES (admin-SDK only) ───────
    match /otp_requests/{docId}    { allow read, write: if false; }
    match /verified_phones/{phone} { allow read, write: if false; }
    match /unmatched_sms/{docId}   { allow read: if isAdmin(); allow write: if false; }

    // ── INVOICES ─────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read, update, delete: if isOwner(resource.data.createdBy) || isAdmin();
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
    }

    // ── EMAIL DRIP ───────────────────────────────────
    match /drip_queue/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    match /drip_log/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── EMAIL / SMS LOG (admin-SDK write, owner read) ─
    match /email_log/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if false;
    }
    match /sms_log/{docId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow write: if false;
    }

    // ── LEAD DOCUMENTS ───────────────────────────────
    match /lead_documents/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── REFERRALS ────────────────────────────────────
    match /referrals/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── REVIEW REQUESTS ──────────────────────────────
    match /review_requests/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── REPORTS ──────────────────────────────────────
    match /reports/{docId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── INVITES (admin-SDK only) ─────────────────────
    match /invites/{token} { allow read, write: if false; }

    // ── AUDIT LOG (admin-only reads, admin-SDK writes) ─
    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── PORTAL TOKENS (admin-SDK only) ─────────────────
    // Minted by createPortalToken, consumed by getHomeownerPortalView.
    // Tokens are sensitive — a leaked token grants read of a
    // homeowner's redacted project view, so clients get no direct
    // access. The homeowner-facing page talks to the HTTP endpoint.
    match /portal_tokens/{token} {
      allow read, write: if false;
    }

    // ── PARCEL CACHE (admin-SDK only) ──────────────────
    // Regrid lookup cache — reads are a privacy issue (address →
    // owner name). Only the Cloud Function accesses via admin SDK.
    match /parcel_cache/{key} {
      allow read, write: if false;
    }

    // ── MEASUREMENTS (rep owner-scoped) ────────────────
    // Created by requestMeasurement, filled by measurementWebhook.
    // Owner can read to pre-fill the V2 Builder; writes are admin-
    // SDK only (webhook).
    match /measurements/{jobId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow write: if false;
    }

    // ── APPOINTMENTS (Cal.com webhook output) ──────────
    // Written by calcomWebhook, read by the owning rep.
    match /appointments/{bookingId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── ACCOUNT ERASURE REQUESTS (admin-SDK only) ──────
    // D7: two-step GDPR erasure. The token hash never leaves the
    // server, so the only way to confirm a deletion is through
    // the confirmAccountErasure HTTP endpoint (which validates the
    // emailed token against the hash).
    match /account_erasures/{uid} {
      allow read, write: if false;
    }

    // ── EMAIL QUEUE (admin-SDK only) ───────────────────
    // Enqueued by server-side flows (GDPR confirmations, dunning,
    // portal invites). A worker processes + clears entries. Clients
    // should never touch this — they'd be able to spoof senders or
    // mine the queue for email addresses.
    match /email_queue/{id} {
      allow read, write: if false;
    }

    // ── DEVICE FINGERPRINTS (admin-SDK only) ───────────
    // D9: per-uid list of seen device fingerprints, used by the
    // new-device Slack alert. Writes only via server triggers.
    match /user_devices/{uid} {
      allow read, write: if false;
      match /seen/{fingerprint} {
        allow read, write: if false;
      }
    }

    // ── FEATURE FLAGS (read by any authed user) ────────
    // F9: _default holds the platform defaults. {uid} is an
    // optional per-user override. Platform admin only writes.
    match /feature_flags/_default {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /feature_flags/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── V2 ESTIMATE DRAFTS (owner only) ────────────────
    // F7: one draft doc per user keyed by uid. Owner reads/writes
    // their own; everyone else (including platform admin) is blocked
    // because drafts are ephemeral + the finalized estimate survives
    // in `estimates/`.
    match /estimate_drafts/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── SMS OPT-OUT LIST (admin-SDK only) ──────────────
    // F3: TCPA compliance. incomingSMS (Twilio webhook) writes here
    // when a recipient replies STOP. sendSMS + sendD2DSMS read it
    // before sending. Both paths go through the admin SDK; clients
    // never need direct access, and leaking the list would identify
    // every number that opted out.
    match /sms_opt_outs/{phone} {
      allow read, write: if false;
    }

    // Entries for the annual "One Free Roof" giveaway. Written only by
    // the submitPublicLead Cloud Function via admin SDK; NBD staff
    // triages entries through the Firebase console (server-side) so no
    // client read surface is needed.
    match /free_roof_entries/{id} {
      allow read, write: if false;
    }

    // Public cache doc for /api/google-reviews. Written by the Cloud
    // Function with admin SDK; clients fetch the function endpoint,
    // never the doc directly.
    match /public_cache/{key} {
      allow read, write: if false;
    }

    // ── STRIPE WEBHOOK IDEMPOTENCY (admin-SDK only) ──
    // F-07 + invoiceWebhook idempotency: stripe.js atomic-creates a
    // doc here keyed by event.id to block duplicate deliveries. The
    // admin SDK bypasses rules; clients never need to touch this.
    // An explicit rule (vs. falling through to default-deny) makes
    // the intent clear for future readers.
    match /stripe_events/{eventId} {
      allow read, write: if false;
    }

    // ── DEFAULT DENY ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
